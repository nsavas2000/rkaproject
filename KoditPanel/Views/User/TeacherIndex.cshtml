@model List<EntityLayer.Concrete.Student>
@{
    ViewData["Title"] = "Öğrenci Listesi";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - RKAPanel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            min-height: 100vh;
            background-color: #f8f9fa;
        }

        /* Sol Menü */
        .sidebar {
            background-color: #343a40;
            color: white;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            width: 240px;
            padding: 20px;
        }

            .sidebar h4 {
                text-align: center;
                margin-bottom: 30px;
            }

            .sidebar a {
                display: block;
                color: white;
                text-decoration: none;
                margin-bottom: 10px;
                padding: 10px 15px;
                border-radius: 6px;
                transition: 0.2s;
            }

                .sidebar a:hover {
                    background-color: #495057;
                }

        .logout-btn {
            margin-top: 20px;
        }

        /* İçerik Alanı */
        .content {
            margin-left: 260px;
            padding: 40px;
        }

        .card {
            border: none;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            border-radius: 12px;
        }

        .table thead th {
            background-color: #212529;
            color: white;
        }

        .btn-info {
            background-color: #0dcaf0;
            border: none;
        }

            .btn-info:hover {
                background-color: #0bb5d1;
            }
    </style>
</head>
<body>

    <!-- Sol Menü -->
    <div class="sidebar">
        <h4>Teacher Panel</h4>

        <a href="/User/TeacherIndex">
            <i class="bi bi-mortarboard me-2"></i>Öğrencilerim
        </a>

        <a href="/User/AddStudent">
            <i class="bi bi-person-plus me-2"></i>Öğrenci Ekle
        </a>

        <form asp-controller="Login" asp-action="Logout" method="post" class="logout-btn">
            <button type="submit" class="btn btn-danger w-100">
                <i class="bi bi-box-arrow-right me-2"></i>Çıkış
            </button>
        </form>
    </div>

    <!-- İçerik -->
    <div class="content">
        <div class="card p-4">
            <h3 class="mb-4">
                <i class="bi bi-mortarboard me-2"></i>Öğrenci Listesi
            </h3>

            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Ad Soyad</th>
                        <th>Kullanıcı Adı</th>
                        <th>Sınıf</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var student in Model)
                        {
                            <tr>
                                <td>@student.Id</td>
                                <td>@student.NameSurname</td>
                                <td>@student.UserName</td>
                                <td>@student.ClassName</td>
                                <td>
                                    <a href="/User/EditStudent/@student.Id"
                                       class="btn btn-warning btn-sm me-1">
                                        <i class="bi bi-pencil-square"></i> Düzenle
                                    </a>

                                    <a href="/User/DeleteStudent/@student.Id"
                                       class="btn btn-danger btn-sm"
                                       onclick="return confirm('Bu öğrenciyi silmek istediğinize emin misiniz?');">
                                        <i class="bi bi-trash"></i> Sil
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">
                                Henüz eklenmiş öğrenci yok
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</body>
</html>
