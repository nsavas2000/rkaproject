@model List<EntityLayer.Concrete.UserLoginLog>
@{
    ViewBag.Title = "Giriş Logları";
    var user = ViewBag.User as EntityLayer.Concrete.User;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - RKAPanel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body {
            min-height: 100vh;
            background-color: #f8f9fa;
        }

        .sidebar {
            background-color: #343a40;
            color: white;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            width: 240px;
            padding: 20px;
        }

            .sidebar h4 {
                text-align: center;
                margin-bottom: 30px;
            }

            .sidebar a {
                display: block;
                color: white;
                text-decoration: none;
                margin-bottom: 10px;
                padding: 10px 15px;
                border-radius: 6px;
                transition: 0.2s;
            }

                .sidebar a:hover {
                    background-color: #495057;
                }

        .logout-btn {
            margin-top: 20px;
        }

        .content {
            margin-left: 260px;
            padding: 30px;
        }

        table th, table td {
            vertical-align: middle !important;
        }
    </style>
</head>
<body>

    <!-- Sol Menü -->
    <div class="sidebar">
        <h4>Admin Panel</h4>
        <a href="/User/Index"><i class="bi bi-clipboard-data me-2"></i>Kullanıcı Logları</a>
        <a href="/User/AddUser"><i class="bi bi-person-plus me-2"></i>Kullanıcı Ekle</a>
        <a href="/User/Users"><i class="bi bi-people me-2"></i>Kullanıcı Bilgileri</a>

        <form asp-controller="Login" asp-action="Logout" method="post" class="logout-btn">
            <button type="submit" class="btn btn-danger w-100">
                <i class="bi bi-box-arrow-right me-2"></i>Çıkış
            </button>
        </form>
    </div>

    <!-- İçerik Alanı -->
    <div class="content">
        <h2 class="mb-4">
            <i class="bi bi-clock-history me-2"></i>@user.NameSurname Kullanıcısının Giriş Logları
        </h2>

        <div class="card shadow-sm">
            <div class="card-body">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 80px;">#</th>
                            <th>Giriş Tarih ve Saat</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            int i = 1;
                            foreach (var log in Model)
                            {
                                <tr>
                                    <td>@i</td>
                                    <td>@log.LoginTime.ToString("g")</td>
                                </tr>
                                i++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="2" class="text-center text-muted">Henüz giriş logu yok</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <a href="/User/Index" class="btn btn-primary mt-3">
            <i class="bi bi-arrow-left-circle me-1"></i> Geri
        </a>
    </div>

</body>
</html>
