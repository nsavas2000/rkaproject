@model EntityLayer.Concrete.Student
@{
    ViewData["Title"] = "Yeni Öğrenci Ekle";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - RKAPanel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            min-height: 100vh;
            background-color: #f8f9fa;
        }

        /* Sol Menü */
        .sidebar {
            background-color: #343a40;
            color: white;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            width: 240px;
            padding: 20px;
        }

            .sidebar h4 {
                text-align: center;
                margin-bottom: 30px;
            }

            .sidebar a {
                display: block;
                color: white;
                text-decoration: none;
                margin-bottom: 10px;
                padding: 10px 15px;
                border-radius: 6px;
                transition: 0.2s;
            }

                .sidebar a:hover {
                    background-color: #495057;
                }

        .logout-btn {
            margin-top: 20px;
        }

        /* İçerik Alanı */
        .content {
            margin-left: 260px;
            padding: 40px;
        }

        .card {
            border: none;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            border-radius: 12px;
        }

        .form-label {
            font-weight: 500;
        }

        .btn-primary {
            border-radius: 8px;
        }
    </style>
</head>
<body>

    <!-- Sol Menü -->
    <div class="sidebar">
        <h4>Teacher Panel</h4>

        <a href="/User/TeacherIndex">
            <i class="bi bi-mortarboard me-2"></i>Öğrencilerim
        </a>

        <a href="/User/AddStudent">
            <i class="bi bi-person-plus me-2"></i>Öğrenci Ekle
        </a>

        <form asp-controller="Login" asp-action="Logout" method="post" class="logout-btn">
            <button type="submit" class="btn btn-danger w-100">
                <i class="bi bi-box-arrow-right me-2"></i>Çıkış
            </button>
        </form>
    </div>

    <!-- İçerik -->
    <div class="content">
        <div class="card p-4">
            <h3 class="mb-4">
                <i class="bi bi-person-plus me-2"></i>Yeni Öğrenci Ekle
            </h3>

            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Ad Soyad</label>
                    <input type="text"
                           name="NameSurname"
                           class="form-control"
                           placeholder="Öğrenci adı soyadı"
                           required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Kullanıcı Adı</label>
                    <input type="text"
                           name="UserName"
                           class="form-control"
                           placeholder="Öğrenci kullanıcı adı"
                           required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Şifre</label>
                    <input type="password"
                           name="Password"
                           class="form-control"
                           placeholder="Öğrenci şifresi"
                           required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Sınıf</label>
                    <input type="text"
                           name="ClassName"
                           class="form-control"
                           placeholder="Örn: 5/A"
                           required />
                </div>

                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-save2 me-2"></i>Kaydet
                </button>

                <a href="/User/TeacherIndex" class="btn btn-secondary ms-2">
                    <i class="bi bi-arrow-left-circle me-1"></i>Geri
                </a>
            </form>
        </div>
    </div>

</body>
</html>
